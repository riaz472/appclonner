modules = ["java-graalvm22.3", "python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["tree"]

[userenv]

[userenv.shared]
ANDROID_HOME = "/home/runner/android-sdk"
ANDROID_SDK_ROOT = "/home/runner/android-sdk"
JAVA_HOME = "/nix/store/r9w6q359r1608viyc13bm7a3h65nhxp0-openjdk-11.0.26+4"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Build Android APK"

[[workflows.workflow]]
name = "Build Android APK"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash setup-android.sh && cd VirtualApp && ./gradlew assembleDebug"

[workflows.workflow.metadata]
outputType = "console"
